<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===== Dudiver Music · paleta neón (basada en el logo) ===== -->

    <!-- Fondos -->
    <Color x:Key="BgDeepColor">#FF0A0A12</Color>       <!-- fondo ventana -->
    <Color x:Key="BgPanelColor">#FF12121F</Color>       <!-- paneles -->
    <Color x:Key="BgPanelAltColor">#FF171728</Color>    <!-- sidebar / filas -->
    <Color x:Key="BgElevatedColor">#FF1E1E32</Color>    <!-- hover / seleccionado -->
    <Color x:Key="StrokeColor">#22FFFFFF</Color>        <!-- bordes sutiles -->

    <!-- Texto -->
    <Color x:Key="TextColor">#FFF2F3FB</Color>
    <Color x:Key="TextMutedColor">#FF8B8DA6</Color>
    <Color x:Key="TextFaintColor">#FF5A5C72</Color>

    <!-- Acentos neón -->
    <Color x:Key="CyanColor">#FF22D3EE</Color>
    <Color x:Key="MagentaColor">#FFEC4899</Color>
    <Color x:Key="PurpleColor">#FFA855F7</Color>
    <Color x:Key="PinkRedColor">#FFE94560</Color>

    <!-- ===== Brushes ===== -->
    <SolidColorBrush x:Key="BgDeep" Color="{StaticResource BgDeepColor}" />
    <SolidColorBrush x:Key="BgPanel" Color="{StaticResource BgPanelColor}" />
    <SolidColorBrush x:Key="BgPanelAlt" Color="{StaticResource BgPanelAltColor}" />
    <SolidColorBrush x:Key="BgElevated" Color="{StaticResource BgElevatedColor}" />
    <SolidColorBrush x:Key="Stroke" Color="{StaticResource StrokeColor}" />

    <SolidColorBrush x:Key="Text" Color="{StaticResource TextColor}" />
    <SolidColorBrush x:Key="TextMuted" Color="{StaticResource TextMutedColor}" />
    <SolidColorBrush x:Key="TextFaint" Color="{StaticResource TextFaintColor}" />

    <SolidColorBrush x:Key="Cyan" Color="{StaticResource CyanColor}" />
    <SolidColorBrush x:Key="Magenta" Color="{StaticResource MagentaColor}" />
    <SolidColorBrush x:Key="Purple" Color="{StaticResource PurpleColor}" />
    <SolidColorBrush x:Key="PinkRed" Color="{StaticResource PinkRedColor}" />

    <!-- Gradiente de marca (play button, activos) -->
    <LinearGradientBrush x:Key="BrandGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource CyanColor}" Offset="0" />
        <GradientStop Color="{StaticResource PurpleColor}" Offset="0.55" />
        <GradientStop Color="{StaticResource MagentaColor}" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="BrandGradientSoft" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#3322D3EE" Offset="0" />
        <GradientStop Color="#33EC4899" Offset="1" />
    </LinearGradientBrush>

    <!-- Glow del logo/play -->
    <RadialGradientBrush x:Key="GlowGradient" GradientOrigin="0.5,0.5" Center="0.5,0.5" RadiusX="0.6" RadiusY="0.6">
        <GradientStop Color="#5522D3EE" Offset="0" />
        <GradientStop Color="#00000000" Offset="1" />
    </RadialGradientBrush>

</ResourceDictionary>
