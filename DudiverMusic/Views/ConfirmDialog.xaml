<Window x:Class="DudiverMusic.Views.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:DudiverMusic.Localization"
        SizeToContent="Height" Width="400"
        WindowStyle="None" ResizeMode="NoResize" ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Background="Transparent" AllowsTransparency="True"
        FontFamily="Segoe UI Variable Text, Segoe UI">

    <Border CornerRadius="16" Background="{DynamicResource BgPanel}"
            BorderBrush="{DynamicResource Stroke}" BorderThickness="1" Padding="26,24">
        <StackPanel HorizontalAlignment="Center">
            <Border Width="52" Height="52" CornerRadius="26" Background="#26E5484D" HorizontalAlignment="Center">
                <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="22"
                           Foreground="#FFFF6B6B" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>

            <TextBlock x:Name="TitleText" HorizontalAlignment="Center" TextAlignment="Center"
                       FontSize="18" FontWeight="SemiBold" Margin="0,14,0,0" TextWrapping="Wrap" />
            <TextBlock x:Name="MessageText" HorizontalAlignment="Center" TextAlignment="Center"
                       FontSize="13.5" Foreground="{DynamicResource TextMuted}" Margin="0,8,0,0"
                       TextWrapping="Wrap" LineHeight="19" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                <Button Style="{StaticResource GhostButton}" Content="{loc:Tr Cancel}"
                        Height="40" Padding="20,0" Click="OnCancel" />
                <Button Content="{loc:Tr Delete}" Height="40" Padding="22,0" Margin="10,0,0,0"
                        Cursor="Hand" Foreground="White" FontWeight="SemiBold" FontSize="13" Click="OnConfirm">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" CornerRadius="20" Background="#FFE5484D">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#FFF25c60" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
