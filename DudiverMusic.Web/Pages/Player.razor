@page "/"
@implements IAsyncDisposable
@inject IJSRuntime JS
@using System.Text.Json
@using System.Globalization

<!-- Inputs reales de archivos: se disparan por <label for> (nativo, mantiene el gesto de usuario). -->
<input id="dmFiles" type="file" multiple accept="audio/*,.mp3,.wav,.flac,.m4a,.aac,.ogg,.opus,.aiff"
       style="display:none" onchange="dudiverPlayer.onInputChange(this, false)" />
<input id="dmFolder" type="file" webkitdirectory directory
       style="display:none" onchange="dudiverPlayer.onInputChange(this, true)" />

<div class="app" @ref="appEl">

    <!-- ===== Top bar ===== -->
    <header class="topbar">
        <div style="display:flex; align-items:center; gap:4px;">
            <button class="chip hamburger" title="@T("YourPlaylists")" @onclick="() => showSidebar = true">@Ico("menu")</button>
            <div class="brand">
                <img src="logo.png" alt="Dudiver Music" />
                <h1><b>Dudiver</b> <span>Music</span></h1>
            </div>
        </div>
        <div class="topbar-actions">
            <a class="donate-btn" href="https://paypal.me/dudivermusic" target="_blank" rel="noopener" title="@T("Donate")">
                @Ico("heart")<span class="donate-txt">@T("DonateShort")</span>
            </a>
            <button class="chip" title="@T("About")" @onclick="() => showAbout = true">@Ico("info")</button>
            <button class="chip" title="@T("Language")" @onclick="ToggleLangPopup">@Ico("globe")</button>
            @if (showLang)
            {
                <div class="pop" style="top:52px; right:0;">
                    <div class="pop-h">@T("Language")</div>
                    @foreach (var l in langs)
                    {
                        <button class="pop-item @(lang == l.Key ? "sel" : "")" @onclick="() => SetLang(l.Key)">
                            <span class="chk">@Ico("check")</span> @l.Value
                        </button>
                    }
                </div>
            }
        </div>
    </header>

    <!-- ===== Body ===== -->
    <div class="body">
        <!-- Sidebar / drawer -->
        <aside class="side @(showSidebar ? "open" : "")">
            <div class="side-head">
                <span class="lbl">@T("YourPlaylists")</span>
                <div style="display:flex; gap:2px;">
                    <button class="chip" style="width:28px;height:28px" title="@T("NewPlaylist")" @onclick="NewPlaylist">@Ico("plus")</button>
                    <button class="chip drawer-close" style="width:28px;height:28px" title="@T("Close")" @onclick="() => showSidebar = false">@Ico("close")</button>
                </div>
            </div>
            <div class="add-row">
                <label class="ghost pick-folder" for="dmFolder" title="@T("TipAddFolder")">@Ico("folder") @T("Folder")</label>
                <label class="ghost" for="dmFiles" title="@T("TipAddFiles")">@Ico("music") @T("Files")</label>
            </div>
            <div class="playlists">
                @foreach (var p in playlists)
                {
                    <div class="pl @(p == selected ? "active" : "")" @onclick="() => Select(p)">
                        <div class="meta">
                            @if (p.IsRenaming)
                            {
                                <input class="rename" value="@p.Name" @onchange="e => CommitRename(p, e)"
                                       @onkeydown="e => RenameKey(p, e)" @onclick:stopPropagation="true"
                                       @ref="renameInput" />
                            }
                            else
                            {
                                <div class="nm">@p.Name</div>
                                <div class="ct">@CountText(p.Tracks.Count)</div>
                            }
                        </div>
                        @if (!p.IsRenaming)
                        {
                            <div class="acts">
                                <button title="@T("TipRename")" @onclick="() => StartRename(p)" @onclick:stopPropagation="true">@Ico("edit")</button>
                                <button title="@T("TipDelete")" @onclick="() => AskDelete(p)" @onclick:stopPropagation="true">@Ico("trash")</button>
                            </div>
                        }
                    </div>
                }
            </div>
        </aside>
        <div class="scrim @(showSidebar ? "show" : "")" @onclick="() => showSidebar = false"></div>

        <!-- Main -->
        <section class="main">
            @if (selected is not null)
            {
                <div class="plview">
                    <div class="plhead">
                        <div>
                            <div class="eyebrow">@T("Playlist")</div>
                            <h2>@selected.Name</h2>
                            <div class="subc">@PlaylistMeta(selected)</div>
                        </div>
                        @if (selected.Tracks.Count > 6)
                        {
                            <div class="search">
                                @Ico("search")
                                <input type="text" placeholder="@T("SearchPh")" value="@search"
                                       @oninput="e => search = e.Value?.ToString() ?? string.Empty" />
                                @if (!string.IsNullOrEmpty(search))
                                {
                                    <button class="search-x" @onclick="() => search = string.Empty">@Ico("close")</button>
                                }
                            </div>
                        }
                    </div>
                    <div class="tracks">
                        @if (VisibleTracks.Count == 0)
                        {
                            <div class="empty-list">@T("NoResults")</div>
                        }
                        @foreach (var t in VisibleTracks)
                        {
                            <div class="tr @(t == current ? "playing" : "")"
                                 draggable="@(CanReorder ? "true" : "false")"
                                 @ondragstart="() => OnDragStart(t)" @ondragover:preventDefault="true"
                                 @ondrop="() => OnDropOn(t)">
                                <div class="ix" @onclick="() => PlayTrack(selected, t)">
                                    @if (t == current)
                                    {
                                        <span class="eq"><i></i><i></i><i></i><i></i></span>
                                    }
                                    else
                                    {
                                        <span class="play">@Ico("play")</span>
                                    }
                                </div>
                                <div class="ti" @onclick="() => PlayTrack(selected, t)">@t.Title</div>
                                <div class="du">@t.DurationText</div>
                                <button class="tr-x" title="@T("RemoveTrack")" @onclick="() => RemoveTrack(t)"
                                        @onclick:stopPropagation="true">@Ico("close")</button>
                            </div>
                        }
                    </div>
                </div>
            }
            else
            {
                <div class="drop">
                    <div class="glow"></div>
                    <div class="drop-in">
                        <img src="logo.png" alt="" />
                        <h3><span class="only-desktop">@T("DropTitle")</span><span class="only-mobile">@T("DropTitleMobile")</span></h3>
                        <p>@T("DropSubtitle")</p>
                        <div class="btns">
                            <label class="pill pick-folder" for="dmFolder">@T("ChooseFolder")</label>
                            <label class="ghost" style="height:40px;padding:0 18px" for="dmFiles">@T("ChooseFiles")</label>
                        </div>
                        <div class="formats">MP3 · WAV · FLAC · M4A · AAC · OGG</div>
                    </div>
                </div>
            }
        </section>
    </div>

    <!-- ===== Now playing ===== -->
    <footer class="now">
        <div class="np">
            <div class="t1">@(current?.Title ?? T("NothingPlaying"))</div>
            <div class="t2">@NowSubtitle</div>
        </div>

        <div class="center">
            <div class="transport">
                <button class="icon-btn @(shuffle ? "on" : "")" title="@T("Shuffle")" @onclick="ToggleShuffle">@Ico("shuffle")</button>
                <button class="icon-btn" title="@T("Previous")" @onclick="Previous">@Ico("prev")</button>
                <button class="play-btn" @onclick="TogglePlay">@Ico(isPlaying ? "pause" : "play")</button>
                <button class="icon-btn" title="@T("Next")" @onclick="Next">@Ico("next")</button>
                <button class="icon-btn @(repeat != 0 ? "on" : "")" title="@RepeatTip()" @onclick="CycleRepeat" style="position:relative">
                    @Ico("repeat")
                    @if (repeat == 2)
                    {
                        <span style="position:absolute;font-size:8px;font-weight:700;bottom:8px;right:8px;color:var(--cyan)">1</span>
                    }
                </button>
            </div>
            <div class="seekrow">
                <span class="time r">@Fmt(position)</span>
                <div class="seek2" title="@T("Seek")">
                    <div class="seek2-track"><div class="seek2-fill" style="width:@(SeekCss)%"></div></div>
                    <div class="seek2-thumb" style="left:@(SeekCss)%"></div>
                </div>
                <span class="time">@Fmt(duration)</span>
            </div>
        </div>

        <div class="vol">
            <button class="icon-btn @(currentDeviceName is not null ? "on" : "")"
                    title="@(currentDeviceName ?? T("Output"))" @onclick="OpenOutput">@Ico("speaker")</button>
            @if (showDevices)
            {
                <div class="pop top" style="right:150px;">
                    <div class="pop-h">@T("Output")</div>
                    @if (outputUnsupported)
                    {
                        <div class="pop-item" style="color:var(--muted)">@T("OutputUnsupported")</div>
                    }
                    else if (devices.Count == 0)
                    {
                        <div class="pop-item" style="color:var(--muted)">@T("NoDevices")</div>
                    }
                    @foreach (var d in devices)
                    {
                        <button class="pop-item @(d.Name == currentDeviceName ? "sel" : "")" @onclick="() => SetDevice(d.Id, d.Name)">
                            <span class="chk">@Ico("check")</span> @d.Name
                        </button>
                    }
                </div>
            }
            <button class="icon-btn" title="@T("Mute")" @onclick="ToggleMute">@Ico(volume <= 0.001 ? "mute" : "volhigh")</button>
            <input type="range" class="volume" min="0" max="1" step="0.02" value="@VolCss" @oninput="OnVolume" />
        </div>
    </footer>

    <!-- ===== Mini-player (mobile) — tap para pantalla completa ===== -->
    <div class="miniplayer" @onclick="() => npExpanded = true">
        <div class="mp-seek"><div class="mp-fill" style="width:@(SeekCss)%"></div></div>
        <div class="mp-art @(isPlaying && currentArtUrl is null ? "spin" : "")"><img src="@(currentArtUrl ?? "logo.png")" alt="" /></div>
        <div class="mp-info">
            <div class="mp-t1">@(current?.Title ?? T("NothingPlaying"))</div>
            <div class="mp-t2">@NowSubtitle</div>
        </div>
        <button class="icon-btn" @onclick:stopPropagation="true" @onclick="TogglePlay">@Ico(isPlaying ? "pause" : "play")</button>
        <button class="icon-btn" @onclick:stopPropagation="true" @onclick="Next">@Ico("next")</button>
    </div>

    <!-- ===== Pantalla completa "Sonando ahora" (mobile) ===== -->
    @if (npExpanded)
    {
        <div class="npfull">
            <div class="npf-top">
                <button class="chip" title="@T("Close")" @onclick="() => npExpanded = false">@Ico("chevrondown")</button>
                <span class="npf-h">@T("NowPlaying")</span>
                <button class="chip @(currentDeviceName is not null ? "on" : "")" title="@T("Output")" @onclick="OpenOutput">@Ico("speaker")</button>
            </div>

            <div class="npf-art @(isPlaying && currentArtUrl is null ? "spin" : "") @(currentArtUrl is not null ? "hasart" : "")">
                <div class="npf-glow"></div>
                <img src="@(currentArtUrl ?? "logo.png")" alt="Dudiver Music" />
            </div>

            <div class="npf-meta">
                <div class="npf-title">@(current?.Title ?? T("NothingPlaying"))</div>
                <div class="npf-sub">@NowSubtitle</div>
            </div>

            <div class="npf-seek">
                <div class="seek2" title="@T("Seek")">
                    <div class="seek2-track"><div class="seek2-fill" style="width:@(SeekCss)%"></div></div>
                    <div class="seek2-thumb" style="left:@(SeekCss)%"></div>
                </div>
                <div class="npf-times"><span>@Fmt(position)</span><span>@Fmt(duration)</span></div>
            </div>

            <div class="npf-controls">
                <button class="icon-btn @(shuffle ? "on" : "")" title="@T("Shuffle")" @onclick="ToggleShuffle">@Ico("shuffle")</button>
                <button class="icon-btn" title="@T("Previous")" @onclick="Previous">@Ico("prev")</button>
                <button class="play-btn" @onclick="TogglePlay">@Ico(isPlaying ? "pause" : "play")</button>
                <button class="icon-btn" title="@T("Next")" @onclick="Next">@Ico("next")</button>
                <button class="icon-btn @(repeat != 0 ? "on" : "")" title="@RepeatTip()" @onclick="CycleRepeat" style="position:relative">
                    @Ico("repeat")
                    @if (repeat == 2)
                    {
                        <span style="position:absolute;font-size:8px;font-weight:700;bottom:9px;right:9px;color:var(--cyan)">1</span>
                    }
                </button>
            </div>
        </div>
    }
</div>

@if (showAbout)
{
    <div class="modal-bg" @onclick="() => showAbout = false">
        <div class="modal" @onclick:stopPropagation="true">
            <button class="x" title="@T("Close")" @onclick="() => showAbout = false">@Ico("close")</button>
            <img class="logo" src="logo.png" alt="Dudiver Music" />
            <h2><b>Dudiver</b> <span>Music</span></h2>
            <div class="ver">@T("Version")</div>
            <div class="tag">@T("AppTagline")</div>
            <div class="story">@T("AboutStory")</div>
            <div class="made">@T("MadeBy")<br /><b>Roberth Dudiver</b> @T("MadeByFrom")</div>
            <div class="links">
                <a href="https://dudiver.net" target="_blank" rel="noopener">dudiver.net</a>
                <a href="https://instagram.com/dudivermusic" target="_blank" rel="noopener">Instagram</a>
                <a href="https://tiktok.com/@@dudivermusic" target="_blank" rel="noopener">TikTok</a>
                <a href="https://youtube.com/@@Dudiver" target="_blank" rel="noopener">YouTube</a>
                <a href="https://github.com/RoberthDudiver" target="_blank" rel="noopener">GitHub</a>
            </div>
            <a class="donate" href="https://paypal.me/dudivermusic" target="_blank" rel="noopener">@Ico("heart") @T("Donate")</a>
            <div class="box">
                <h4>@T("LicenseHeader")</h4>
                <p>@T("LicenseText")</p>
            </div>
            <div class="box">
                <h4>@T("TermsHeader")</h4>
                <p>@T("TermsText")</p>
            </div>
        </div>
    </div>
}

@if (toDelete is not null)
{
    <div class="modal-bg" @onclick="CancelDelete">
        <div class="confirm" @onclick:stopPropagation="true">
            <div class="confirm-ic">@Ico("trash")</div>
            <h3>@T("DeleteTitle")</h3>
            <p>@(string.Format(T("DeleteText"), toDelete.Name))</p>
            <div class="confirm-btns">
                <button class="ghost" style="height:40px;padding:0 20px" @onclick="CancelDelete">@T("Cancel")</button>
                <button class="danger" @onclick="ConfirmDelete">@T("Delete")</button>
            </div>
        </div>
    </div>
}

@if (toast is not null)
{
    <div class="toast" @onclick="() => toast = null">@Ico("info") <span>@toast</span></div>
}

@code {
    // ===== Estado =====
    List<Playlist> playlists = new();
    Playlist? selected;
    Playlist? playingList;
    Track? current;
    bool isPlaying;
    double position, duration;
    double volume = 0.8, volumeBeforeMute = 0.8;
    bool shuffle;
    int repeat; // 0 off, 1 all, 2 one
    readonly Random rng = new();

    // Popups / dispositivos / drawer / full-screen
    bool showDevices, showLang, showAbout, outputUnsupported, showSidebar, npExpanded;

    // Avisos (toast)
    string? toast;
    int _toastId;
    void Toast(string msg)
    {
        toast = msg;
        var id = ++_toastId;
        _ = DelayClearToast(id);
    }
    async Task DelayClearToast(int id)
    {
        await Task.Delay(5000);
        if (_toastId == id) { toast = null; StateHasChanged(); }
    }
    double SeekPct => duration > 0 ? Math.Clamp(position / duration * 100, 0, 100) : 0;
    // CSS invariante (la app puede correr en cultura con coma decimal → "18,4%" rompería el CSS/attr)
    string SeekCss => SeekPct.ToString("0.###", CultureInfo.InvariantCulture);
    string VolCss => volume.ToString("0.###", CultureInfo.InvariantCulture);
    List<AudioDeviceInfo> devices = new();
    string? currentDeviceName;

    // Interop
    ElementReference appEl;
    ElementReference renameInput;
    DotNetObjectReference<Player>? selfRef;
    bool jsReady;

    // ===== i18n =====
    string lang = "es";
    readonly Dictionary<string, string> langs = new() { ["es"] = "Español", ["en"] = "English" };

    protected override async Task OnAfterRenderAsync(bool first)
    {
        if (first)
        {
            selfRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("dudiverPlayer.init", selfRef);
            await JS.InvokeVoidAsync("dudiverPlayer.attachDrop", appEl);
            jsReady = true;
            await LoadLibrary();
            await JS.InvokeVoidAsync("dudiverPlayer.setVolume", volume);
        }
        if (pendingFocusRename)
        {
            pendingFocusRename = false;
            try { await renameInput.FocusAsync(); } catch { }
        }
    }

    // ===== Callbacks desde JS =====
    [JSInvokable] public void OnTime(double t) { if (current is null) return; position = double.IsFinite(t) ? t : 0; StateHasChanged(); }
    [JSInvokable] public void OnLoaded(double d)
    {
        if (current is null) return; // se paró/borró la pista antes de cargar

        // MP3 VBR pueden reportar Infinity/NaN → usar la duración ya leída del archivo.
        duration = double.IsFinite(d) && d > 0 ? d : (current?.DurationSeconds ?? 0);
        if (current is not null && double.IsFinite(d) && d > 0) current.DurationSeconds = d;
        StateHasChanged();
    }
    [JSInvokable] public void OnPlayState(bool playing) { isPlaying = playing; StateHasChanged(); }
    [JSInvokable] public void OnEnded() => _ = TrackFinished();

    int _playFailStreak;
    // El navegador no pudo decodificar/cargar la pista (código 3=decode, 4=formato no soportado).
    [JSInvokable]
    public async Task OnAudioError(int code, string name)
    {
        isPlaying = false;
        _playFailStreak++;
        var list = playingList?.Tracks;
        // Si venimos saltando y ya fallaron todas, paramos y avisamos (sin bucle infinito).
        if (list is not null && _playFailStreak >= list.Count)
        {
            _playFailStreak = 0;
            Toast(T("ErrAllFailed"));
            StateHasChanged();
            return;
        }
        Toast(string.Format(T("ErrUnplayable"), string.IsNullOrEmpty(name) ? (current?.Title ?? "") : name));
        StateHasChanged();
        await Advance(auto: true); // intenta la siguiente
    }

    // Barra de progreso propia: JS envía la fracción (0..1) del click/arrastre.
    [JSInvokable]
    public async Task SeekFraction(double frac)
    {
        if (duration <= 0) return;
        position = Math.Clamp(frac, 0, 1) * duration;
        StateHasChanged();
        await JS.InvokeVoidAsync("dudiverPlayer.seek", position);
    }

    [JSInvokable]
    public async Task OnFilesDropped(PickedFile[] files) => await AddPicked(files);

    // ===== Cargar archivos / carpetas =====
    // Regla simple y predecible: si hay una playlist seleccionada, se agrega a ella
    // (sea archivos o carpeta). Si no hay ninguna, se crea una nueva. Para separar
    // en otra playlist, el usuario toca "+" (crea una vacía) y luego agrega.
    [JSInvokable]
    public async Task OnFilesPicked(PickedFile[] files, bool isFolder) => await AddPicked(files);

    async Task AddPicked(PickedFile[] files)
    {
        if (files is null || files.Length == 0) return;
        var tracks = files.Select(f => new Track { Id = f.Id, Title = f.Name }).ToList();

        // Nombre sugerido: carpeta común, si la hay.
        var folders = files.Select(f => f.Folder).Where(x => !string.IsNullOrEmpty(x)).Distinct().ToList();
        string suggested = folders.Count == 1 ? folders[0] : T("MySongs");

        Playlist? target = selected;
        if (target is null)
        {
            target = new Playlist { Name = suggested };
            playlists.Add(target);
            selected = target;
        }
        else if (target.Tracks.Count == 0 && folders.Count == 1)
        {
            target.Name = suggested; // playlist vacía + carpeta → hereda el nombre de la carpeta
        }
        int added = tracks.Count;
        target.Tracks.AddRange(tracks);
        showSidebar = false;
        Toast(string.Format(T(added == 1 ? "AddedOne" : "AddedMany"), added, target.Name));
        StateHasChanged();
        await Persist();
        _ = LoadDurations(tracks);   // en segundo plano
        _ = LoadTags(tracks);        // artista/álbum/carátula en segundo plano
        _ = WarnUnsupported(files);  // avisa si hay formatos que el navegador no reproduce
    }

    // Avisa si el navegador no puede reproducir algunos formatos (ej. AIFF, WMA).
    async Task WarnUnsupported(PickedFile[] files)
    {
        try
        {
            var names = files.Select(f => string.IsNullOrEmpty(f.File) ? f.Name : f.File).ToArray();
            var bad = await JS.InvokeAsync<string[]>("dudiverPlayer.unsupported", new object[] { names });
            if (bad.Length > 0) Toast(string.Format(T("WarnUnsupported"), bad.Length));
        }
        catch { }
    }

    // ===== Duraciones (en segundo plano) =====
    async Task LoadDurations(List<Track> tracks)
    {
        var pending = tracks.Where(t => t.DurationSeconds <= 0).Select(t => t.Id).ToArray();
        if (pending.Length == 0) return;
        try
        {
            var durs = await JS.InvokeAsync<DurDto[]>("dudiverPlayer.getDurations", pending);
            var map = tracks.ToDictionary(t => t.Id);
            foreach (var d in durs)
                if (d.Dur > 0 && map.TryGetValue(d.Id, out var tr)) tr.DurationSeconds = d.Dur;
            StateHasChanged();
            await Persist();
        }
        catch { }
    }

    // ===== Tags ID3 (artista/álbum/carátula) en segundo plano =====
    async Task LoadTags(List<Track> tracks)
    {
        var pending = tracks.Where(t => string.IsNullOrEmpty(t.Artist)).ToList();
        if (pending.Count == 0) return;
        try
        {
            var tags = await JS.InvokeAsync<TagDto[]>("dudiverPlayer.getTags", pending.Select(t => t.Id).ToArray());
            var map = tracks.ToDictionary(t => t.Id);
            bool changed = false;
            foreach (var tag in tags)
            {
                if (!map.TryGetValue(tag.Id, out var tr)) continue;
                if (!string.IsNullOrWhiteSpace(tag.Artist)) { tr.Artist = tag.Artist; changed = true; }
                if (!string.IsNullOrWhiteSpace(tag.Album)) { tr.Album = tag.Album; changed = true; }
            }
            if (changed) { StateHasChanged(); await Persist(); }
            if (current is not null && tracks.Contains(current)) await UpdateNowPlaying();
        }
        catch { }
    }

    // ===== Persistencia (IndexedDB) =====
    bool _loading;

    async Task Persist()
    {
        if (_loading || !jsReady) return;
        var data = playlists.Select(p => new PlDto(
            p.Id, p.Name,
            p.Tracks.Select(t => new TrDto(t.Id, t.Title, t.DurationSeconds, t.Artist, t.Album)).ToList())).ToList();
        try { await JS.InvokeVoidAsync("dudiverPlayer.savePlaylists", JsonSerializer.Serialize(data)); } catch { }
    }

    async Task LoadLibrary()
    {
        _loading = true;
        try
        {
            var json = await JS.InvokeAsync<string?>("dudiverPlayer.loadPlaylists");
            if (!string.IsNullOrEmpty(json))
            {
                var data = JsonSerializer.Deserialize<List<PlDto>>(json);
                if (data is not null)
                {
                    playlists = data.Select(p => new Playlist
                    {
                        Id = p.Id,
                        Name = p.Name,
                        Tracks = p.Tracks.Select(t => new Track { Id = t.Id, Title = t.Title, DurationSeconds = t.Dur, Artist = t.Artist, Album = t.Album }).ToList()
                    }).ToList();
                    selected = playlists.FirstOrDefault();
                }
            }
        }
        catch { }
        finally { _loading = false; StateHasChanged(); }
    }

    record PlDto(string Id, string Name, List<TrDto> Tracks);
    record TrDto(string Id, string Title, double Dur, string? Artist, string? Album);
    record DurDto(string Id, double Dur);
    record TagDto(string Id, string Title, string Artist, string Album, bool HasArt);

    // ===== Reproducción =====
    string? currentArtUrl;
    string NowSubtitle => current?.Artist ?? playingList?.Name ?? "";

    async Task PlayTrack(Playlist pl, Track t)
    {
        playingList = pl;
        current = t;
        position = 0; duration = t.DurationSeconds;
        string status;
        try
        {
            // JsonElement (no string) para tolerar una versión vieja de player.js en caché
            // que devolvía bool (true=sonando / false=sin blob) y no romper el render.
            var res = await JS.InvokeAsync<JsonElement>("dudiverPlayer.play", t.Id, t.Title);
            status = res.ValueKind switch
            {
                JsonValueKind.String => res.GetString() ?? "ok",
                JsonValueKind.True => "ok",
                JsonValueKind.False => "missing",
                _ => "ok"
            };
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"[Dudiver] interop play falló: {ex.Message}");
            status = "ok";
        }
        if (status != "ok")
        {
            isPlaying = false;
            if (status == "missing")
                Toast(string.Format(T("ErrMissing"), t.Title));
            else // blocked: el navegador exige gesto del usuario
                Toast(T("ErrBlocked"));
            StateHasChanged();
            return;
        }
        _playFailStreak = 0;
        isPlaying = true;
        StateHasChanged();
        await UpdateNowPlaying();
    }

    // Carátula + metadatos del SO para la canción actual.
    async Task UpdateNowPlaying()
    {
        if (current is null) return;
        try
        {
            currentArtUrl = await JS.InvokeAsync<string?>("dudiverPlayer.getArtUrl", current.Id);
            await JS.InvokeVoidAsync("dudiverPlayer.setNowPlaying",
                current.Title, current.Artist ?? "", current.Album ?? "", currentArtUrl);
            StateHasChanged();
        }
        catch { }
    }

    // ===== Media Session (controles del SO) + atajos de teclado =====
    [JSInvokable]
    public async Task OnMediaAction(string action)
    {
        switch (action)
        {
            case "play": case "pause": await TogglePlay(); break;
            case "next": await Next(); break;
            case "prev": await Previous(); break;
        }
    }

    [JSInvokable]
    public async Task OnKey(string k)
    {
        switch (k)
        {
            case "space": await TogglePlay(); break;
            case "right": if (duration > 0) { position = Math.Min(duration, position + 5); await JS.InvokeVoidAsync("dudiverPlayer.seek", position); } break;
            case "left": position = Math.Max(0, position - 5); await JS.InvokeVoidAsync("dudiverPlayer.seek", position); break;
            case "volup": volume = Math.Min(1, volume + 0.05); await JS.InvokeVoidAsync("dudiverPlayer.setVolume", volume); StateHasChanged(); break;
            case "voldown": volume = Math.Max(0, volume - 0.05); await JS.InvokeVoidAsync("dudiverPlayer.setVolume", volume); StateHasChanged(); break;
        }
    }

    async Task TogglePlay()
    {
        if (current is null)
        {
            var first = selected?.Tracks.FirstOrDefault();
            if (first is not null) await PlayTrack(selected!, first);
            return;
        }
        if (isPlaying) await JS.InvokeVoidAsync("dudiverPlayer.pause");
        else await JS.InvokeVoidAsync("dudiverPlayer.resume");
    }

    async Task Next() => await Advance(auto: false);

    async Task TrackFinished()
    {
        if (repeat == 2 && current is not null) { await PlayTrack(playingList!, current); return; }
        await Advance(auto: true);
    }

    async Task Advance(bool auto)
    {
        var list = playingList?.Tracks;
        if (list is null || list.Count == 0 || current is null) return;
        int idx = list.IndexOf(current);
        int next;
        if (shuffle && list.Count > 1) { do { next = rng.Next(list.Count); } while (next == idx); }
        else
        {
            next = idx + 1;
            if (next >= list.Count)
            {
                if (repeat != 0 || !auto) next = 0;
                else { isPlaying = false; StateHasChanged(); return; }
            }
        }
        await PlayTrack(playingList!, list[next]);
    }

    async Task Previous()
    {
        var list = playingList?.Tracks;
        if (list is null || list.Count == 0 || current is null) return;
        if (position > 3) { await JS.InvokeVoidAsync("dudiverPlayer.seek", 0); return; }
        int idx = list.IndexOf(current);
        int prev = idx - 1;
        if (prev < 0) prev = repeat != 0 ? list.Count - 1 : 0;
        await PlayTrack(playingList!, list[prev]);
    }

    async Task OnSeek(ChangeEventArgs e)
    {
        if (double.TryParse(e.Value?.ToString(), System.Globalization.CultureInfo.InvariantCulture, out var s))
        { position = s; await JS.InvokeVoidAsync("dudiverPlayer.seek", s); }
    }

    async Task OnVolume(ChangeEventArgs e)
    {
        if (double.TryParse(e.Value?.ToString(), System.Globalization.CultureInfo.InvariantCulture, out var v))
        { volume = v; await JS.InvokeVoidAsync("dudiverPlayer.setVolume", v); }
    }

    async Task ToggleMute()
    {
        if (volume > 0.001) { volumeBeforeMute = volume; volume = 0; }
        else volume = volumeBeforeMute <= 0.001 ? 0.8 : volumeBeforeMute;
        await JS.InvokeVoidAsync("dudiverPlayer.setVolume", volume);
    }

    void ToggleShuffle() => shuffle = !shuffle;
    void CycleRepeat() => repeat = (repeat + 1) % 3;
    string RepeatTip() => repeat switch { 1 => T("RepeatAll"), 2 => T("RepeatOne"), _ => T("RepeatOff") };

    // ===== Playlists =====
    string search = "";
    Playlist? toDelete;
    Track? dragTrack;

    List<Track> VisibleTracks => selected is null ? new()
        : string.IsNullOrWhiteSpace(search) ? selected.Tracks
        : selected.Tracks.Where(t => t.Title.Contains(search.Trim(), StringComparison.OrdinalIgnoreCase)).ToList();
    bool CanReorder => string.IsNullOrWhiteSpace(search);

    string PlaylistMeta(Playlist p)
    {
        int n = p.Tracks.Count;
        var count = n == 1 ? T("SongOne") : string.Format(T("SongMany"), n);
        double total = p.Tracks.Sum(t => t.DurationSeconds);
        return total > 0 ? $"{count} · {DurText(total)}" : count;
    }
    static string DurText(double s)
    {
        var ts = TimeSpan.FromSeconds(s);
        return ts.TotalHours >= 1 ? $"{(int)ts.TotalHours} h {ts.Minutes} min" : $"{ts.Minutes} min";
    }

    void Select(Playlist p) { selected = p; search = ""; showSidebar = false; }

    async Task NewPlaylist()
    {
        var p = new Playlist { Name = T("NewPlaylistName"), IsRenaming = true };
        playlists.Add(p);
        selected = p; search = "";
        pendingFocusRename = true; showSidebar = false;
        await Persist();
    }

    bool pendingFocusRename;
    void StartRename(Playlist p) { p.IsRenaming = true; pendingFocusRename = true; }
    async Task CommitRename(Playlist p, ChangeEventArgs e)
    {
        var v = e.Value?.ToString();
        if (!string.IsNullOrWhiteSpace(v)) p.Name = v!.Trim();
        p.IsRenaming = false;
        await Persist();
    }
    void RenameKey(Playlist p, KeyboardEventArgs e)
    {
        if (e.Key is "Enter" or "Escape") p.IsRenaming = false;
    }

    // Borrar playlist (con confirmación)
    void AskDelete(Playlist p) { toDelete = p; }
    void CancelDelete() => toDelete = null;
    async Task ConfirmDelete()
    {
        if (toDelete is null) return;
        playlists.Remove(toDelete);
        if (selected == toDelete) { selected = playlists.FirstOrDefault(); search = ""; }
        // Si se está reproduciendo algo de la playlist borrada, parar.
        if (playingList == toDelete) await StopPlayback();
        toDelete = null;
        StateHasChanged();
        await PersistAndPrune();
    }

    // Quitar una pista de la playlist
    async Task RemoveTrack(Track t)
    {
        if (selected is null) return;
        selected.Tracks.Remove(t);
        // Si es la pista que suena, parar el audio y limpiar el estado (si no, queda
        // apuntando a un blob que además se borra en el prune → error).
        if (current == t) await StopPlayback();
        StateHasChanged();
        await PersistAndPrune();
    }

    // Para la reproducción y limpia todo el estado de "sonando".
    async Task StopPlayback()
    {
        try { await JS.InvokeVoidAsync("dudiverPlayer.stop"); } catch { }
        current = null; playingList = null; isPlaying = false;
        position = 0; duration = 0; currentArtUrl = null;
    }

    // Reordenar por drag
    void OnDragStart(Track t) => dragTrack = t;
    async Task OnDropOn(Track target)
    {
        if (selected is null || dragTrack is null || dragTrack == target) { dragTrack = null; return; }
        var list = selected.Tracks;
        list.Remove(dragTrack);
        list.Insert(list.IndexOf(target), dragTrack);
        dragTrack = null;
        await Persist();
    }

    async Task PersistAndPrune()
    {
        await Persist();
        var keep = playlists.SelectMany(p => p.Tracks.Select(t => t.Id)).Distinct().ToArray();
        try { await JS.InvokeVoidAsync("dudiverPlayer.pruneBlobs", keep); } catch { }
    }

    // ===== Dispositivos de salida =====
    async Task OpenOutput()
    {
        showLang = false;
        // Preferir el selector NATIVO del navegador (no pide micrófono, IDs válidos).
        if (await JS.InvokeAsync<bool>("dudiverPlayer.supportsPicker"))
        {
            var d = await JS.InvokeAsync<AudioDeviceInfo?>("dudiverPlayer.pickOutput");
            if (d is not null) currentDeviceName = d.Name;
            return;
        }
        // Fallback: lista enumerada + setSinkId.
        showDevices = !showDevices;
        if (showDevices)
        {
            outputUnsupported = !await JS.InvokeAsync<bool>("dudiverPlayer.supportsSink");
            devices = outputUnsupported
                ? new()
                : (await JS.InvokeAsync<AudioDeviceInfo[]>("dudiverPlayer.getDevices")).ToList();
        }
    }
    async Task SetDevice(string id, string name)
    {
        currentDeviceName = name; showDevices = false;
        await JS.InvokeVoidAsync("dudiverPlayer.setSink", id);
    }

    // ===== i18n / helpers =====
    void ToggleLangPopup() { showLang = !showLang; showDevices = false; }
    void SetLang(string l) { lang = l; showLang = false; }
    string T(string key) => (lang == "en" ? En : Es).TryGetValue(key, out var v) ? v : key;
    string CountText(int n) => n == 1 ? T("SongOne") : string.Format(T("SongMany"), n);

    static string Fmt(double s)
    {
        if (!double.IsFinite(s) || s <= 0) return "0:00";
        var ts = TimeSpan.FromSeconds(s);
        return ts.TotalHours >= 1 ? ts.ToString(@"h\:mm\:ss") : ts.ToString(@"m\:ss");
    }

    public async ValueTask DisposeAsync()
    {
        selfRef?.Dispose();
        if (jsReady) { try { await JS.InvokeVoidAsync("dudiverPlayer.pause"); } catch { } }
    }

